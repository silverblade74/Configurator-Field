rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isLeaderOrAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'ministry_leader'];
    }

    // Protected fields that only admins can change
    function noProtectedFieldChanges() {
      let diff = request.resource.data.diff(resource.data).affectedKeys();
      return !diff.hasAny(['role', 'totalHours', 'totalPoints', 'badges', 'streak', 'managed', 'assignedDepartment']);
    }

    // Users: volunteers can only update safe fields on their own profile
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAuth() && (request.auth.uid == userId || isAdmin());
      allow update: if isAuth() && (
        (request.auth.uid == userId && noProtectedFieldChanges()) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Ministries
    match /ministries/{ministryId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // Events
    match /events/{eventId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // Event Signups
    match /eventSignups/{signupId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow delete: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
    }

    // Attendance Logs
    match /attendanceLogs/{logId} {
      allow read: if isAuth();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // Service Hours
    match /serviceHours/{hourId} {
      allow read: if isAuth();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }
  }
}
